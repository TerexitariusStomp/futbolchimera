{
  "name": "chimera-mobile-expo",
  "version": "1.0.22",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android": "eas build -p android --profile preview",
    "build:ios": "eas build -p ios --profile preview",
    "build:pear-worker": "node scripts/build-pear-worker.js",
    "build:qvac-worker": "node scripts/build-qvac-worker.js",
    "build:workers": "npm run build:pear-worker && npm run build:qvac-worker",
    "postinstall": "node scripts/patch-bare-kit.js && node scripts/patch-qvac-sdk.js"
  },
  "dependencies": {
    "@hyperswarm/secret-stream": "^6.0.0",
    "@localchimera/sdk": "file:../../sdk",
    "@qvac/sdk": "^0.13.2",
    "b4a": "^1.6.6",
    "expo": "~52.0.0",
    "expo-bare-kit": "^0.1.1",
    "expo-device": "~6.0.0",
    "expo-file-system": "~18.0.0",
    "expo-keep-awake": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "hypercore": "^10.0.0",
    "hyperswarm": "^4.0.0",
    "react": "18.3.1",
    "react-native": "0.76.0",
    "react-native-bare-kit": "^0.15.0",
    "react-native-webview": "13.12.5",
    "tinyld": "^1.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@react-native-community/cli": "^20.2.0",
    "bare-pack": "^2.2.0",
    "expo-build-properties": "~0.13.0"
  },
  "private": true
}
